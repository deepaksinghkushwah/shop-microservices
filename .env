# ============================================
# Microservices Configuration
# ============================================
# This file is used for Docker Compose deployment
# For local binary builds, service-specific .env files are in dist/<service>/

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET='8df87D121m$fs*sdf!@'

# ============================================
# Service Ports
# ============================================
AUTH_SERVICE_PORT=8081
CATALOG_SERVICE_PORT=8082
ORDER_SERVICE_PORT=8083

# ============================================
# PostgreSQL Database Configuration
# ============================================
# These credentials are used by docker-compose
# to set up the PostgreSQL container and for
# service connections.

DB_HOST=postgres          # Docker service name (docker-compose networking)
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password      # CHANGE THIS IN PRODUCTION!
DB_SSLMODE=disable

# Database names (created automatically by init-db.sql)
# auth-service -> auth
# catalog-service -> catalog
# order-service -> order

# ============================================
# Local Development (Non-Docker)
# ============================================
# When running services locally (not in Docker),
# each service gets its own .env file in dist/<service>/
# 
# For local setup with local PostgreSQL:
#   DB_HOST=localhost
#   DB_PORT=5432
#   DB_USER=postgres
#   DB_PASSWORD=password
#   DB_SSLMODE=disable
